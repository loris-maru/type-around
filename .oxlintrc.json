{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "nextjs", "jsx-a11y"],
  "categories": {
    "correctness": "error",
    "suspicious": "off",
    "perf": "off",
    "nursery": "off",
    "pedantic": "off",
    "restriction": "off",
    "style": "off"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["^(\\./|\\.\\./).*"],
            "message": "Use absolute imports with @ alias instead of relative imports (e.g., use '@/components/...' instead of './components/...' or '../components/...')."
          }
        ]
      }
    ],
    "jsx-a11y/no-static-element-interactions": "warn",
    "jsx-a11y/click-events-have-key-events": "warn",
    "jsx-a11y/no-noninteractive-element-interactions": "warn",
    "jsx-a11y/control-has-associated-label": "off",
    "jsx-a11y/prefer-tag-over-role": "off"
  },
  "ignorePatterns": [
    ".next/**",
    "out/**",
    "build/**",
    "next-env.d.ts",
    "node_modules/**",
    "playwright-report/**",
    "test-results/**",
    "tsconfig.tsbuildinfo",
    "types/paypal-checkout-server-sdk.d.ts"
  ]
}
