{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": false,
  "printWidth": 60,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "bracketSpacing": true,
  "singleAttributePerLine": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "bun.lock",
    ".next/**",
    "out/**",
    "build/**",
    "node_modules/**",
    "playwright-report/**",
    "test-results/**",
    "next-env.d.ts",
    "tsconfig.tsbuildinfo"
  ]
}
